# 站点公网 URL（用于 sitemap、SEO）
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Formspree 表单 ID，用于首页留言板
# 注册 https://formspree.io 获取
NEXT_PUBLIC_FORMSPREE_ID=your_form_id

# 管理密码：访问 /upload、/manage 时需输入此密码（生产环境必设）
# 不设置则管理功能不保护（仅本地开发用）
ADMIN_SECRET=your_secure_password

# 是否在导航栏显示「上传」「管理」入口（true=显示，不设或false=隐藏）
# 生产环境建议不设，通过书签访问 /admin-login
NEXT_PUBLIC_SHOW_ADMIN=false
